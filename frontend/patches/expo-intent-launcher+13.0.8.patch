+        // PATCH: EPOS Open API нь `amount`, `tipAmount`, `traceNo` гэх мэт Long
+        // утгуудыг шаардана (Bundle.getLong-аар уншина). expo-intent-launcher нь
+        // анхдагчаар бүх Double-ийг Int-руу хөрвүүлдэг тул type mismatch үүснэ.
+        // Нэр нь "_long" -ээр төгсөж буй түлхүүрүүдийг Long-аар оруулна.
+        val valuesList = it.mapValues { (key, value) ->
+          if (value is Double) {
+            if (key.endsWith("_long")) value.toLong() else value.toInt()
