UTH_CANCEL: \"android.epos.payment.preAuthCancel\",\n    PRE_AUTH_COMPLETION: \"android.epos.payment.preAuthCompletion\",\n    SETTLE: \"android.epos.payment.settle\",\n    CHECK_TRANS: \"android.epos.payment.checkTrans\",\n    CITIZEN_CARD: \"android.epos.payment.citizenCard\",\n    PRINT_BITMAP: \"android.epos.payment.printBitmap\",\n    REPRINT_TRANS: \"android.epos.payment.reprintTrans\",\n    REPRINT_TOTAL: \"android.epos.payment.reprintTotal\",\n    SCAN_CODE: \"android.epos.payment.scanCode\",\n    READ_RF_CARD: \"android.epos.payment.readRfCard\",\n    HEALTH_CHECK: \"android.epos.payment.healthCheck\"\n  };\n  const EPOS_COMMAND_TYPE = {\n    SALE: \"1\",\n    VOID: \"3\",\n    VOID_CARD: \"5\",\n    PRE_AUTH: \"12\",\n    PRE_AUTH_CANCEL: \"13\",\n    PRE_AUTH_COMPLETION: \"13\",\n    SCAN_CODE: \"35\",\n    READ_RF_CARD: \"42\"\n  };\n\n  // Runtime overrides (PAX Debug дэлгэцээс)\n  let _runtimeOverrides = null;\n  let _overridesLoaded = false;\n  async function loadOverrides() {\n    if (_overridesLoaded) return;\n    try {\n      const raw = await AsyncStorage.default.getItem(PAX_OVERRIDES_KEY);\n      if (raw) _runtimeOverrides = JSON.parse(raw);\n    } catch (_) {}\n    _overridesLoaded = true;\n  }\n  function currentCfg() {\n    const o = _runtimeOverrides || {};\n    return {\n      pkg: o.pkg || process.env.EXPO_PUBLIC_PAX_PACKAGE || \"\",\n      // 🆕 default empty — Android-ийг intent-ийн action/category-аар resolve хийлгэнэ\n      amountUnit: o.amountUnit || process.env.EXPO_PUBLIC_PAX_AMOUNT_UNIT || \"major\",\n      // 🆕 Intent style:\n      //   \"action\"   — категори утгыг action болгож илгээнэ (ихэнхдээ ажилладаг)\n      //   \"category\" — PDF-ийн дагуу action=MAIN, category=...\n      //   \"both\"     — action=category + category=category хоёуланг нь\n      intentStyle: o.intentStyle || process.env.EXPO_PUBLIC_PAX_INTENT_STYLE || \"action\"\n    };\n  }\n  function paxConfig() {\n    return {\n      ...currentCfg(),\n      action: EPOS