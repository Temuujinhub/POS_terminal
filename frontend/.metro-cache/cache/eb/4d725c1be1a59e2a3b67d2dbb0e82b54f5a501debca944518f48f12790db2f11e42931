0)),\n        batch_no: \"001\",\n        masked_pan: \"**** **** **** 4321\",\n        card_type: \"VISA\",\n        cardholder_name: \"TEST/CUSTOMER\",\n        entry_mode: \"Contactless\",\n        terminal_id: \"EPOSDEMO\",\n        merchant_id: \"990000000001\",\n        merchant_name: \"PETROL POS\",\n        amount: fmtAmount(amountMnt),\n        simulated: true,\n        raw: {\n          dbRefNo,\n          simulated: true\n        }\n      };\n    }\n    try {\n      const {\n        resultCode,\n        extra,\n        raw\n      } = await startEposIntent(EPOS_CATEGORY.SALE, EPOS_COMMAND_TYPE.SALE, {\n        amount: fmtAmount(amountMnt),\n        dbRefNo\n      });\n      const ok = resultCode === -1;\n      const rsp = String(extra.rspCode || \"\").trim();\n      const hasApproval = !!(extra.authCode || extra.approvalCode);\n      const success = ok && rsp === \"000\" && hasApproval;\n      return {\n        ok: success,\n        rsp_code: rsp || undefined,\n        rsp_msg: extra.rspMsg,\n        approval_code: extra.authCode || extra.approvalCode,\n        rrn: extra.rrn,\n        trace_no: extra.traceNo ? String(extra.traceNo) : undefined,\n        batch_no: extra.batchNo ? String(extra.batchNo) : undefined,\n        masked_pan: extra.cardNo,\n        card_type: extra.cardType,\n        cardholder_name: extra.cardHolderName,\n        entry_mode: extra.entryModeText,\n        terminal_id: extra.terminalId,\n        merchant_id: extra.merchantId,\n        merchant_name: extra.merchantName,\n        amount: extra.amount,\n        raw,\n        error: success ? undefined : extra.rspMsg || `rspCode=${rsp || \"?\"} / resultCode=${resultCode}`\n      };\n    } catch (e) {\n      return {\n        ok: false,\n        error: e?.message || \"EPOS интент явуулахад алдаа гарлаа\",\n        raw: e\n      };\n    }\n  }\n\n  /* ============================================================\n   *  QPAY / SCAN CODE — QR код уншуулах (commandType=35)\n   * ============