# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
dist/
dist

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store

# Python
__pycache__/
*pyc*
venv/
.venv/

# Development tools
chainlit.md
.chainlit
.ipynb_checkpoints/
.ac

# Deployment
.vercel

# Data and databases
agenthub/agents/youtube/db

# Archive files
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/

# Sensitive credential / runtime files (NOT including .env which EAS / Emergent deployer require)
memory/test_credentials.md
*token.json*
credentials.json
.credentials

# Local-only env overrides (allow committing .env / .env.production for EAS builds)
.env.local
.env.*.local
*.env.local

# Mobile development - signing keys & native build artifacts
*.jks
*.p8
*.p12
*.keystore
.kotlin/
android/app/build/
ios/build/
ios/Pods/

# Expo build artifacts
.expo/
.expo-shared/
web-build/
expo-env.d.ts
.env
.env.*
*.env
*.pem
*.key
